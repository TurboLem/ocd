                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <PagerContent>
                        <MudDataGridPager />
                    </PagerContent>
                </MudDataGrid>
            </MudTabPanel>
        </MudTabs>

    </Authorized>
    <NotAuthorized>
        <MudAlert Severity="Severity.Error">You are not authorized to view this page.</MudAlert>
    </NotAuthorized>
</AuthorizeView>
@code {
    private int activeIndex;
    private int totalCampaignsCount;
    private int activeCampaignsCount;
    private int inactiveCampaignsCount;
    private int pendingCampaignsCount;
    private int unreadCommentsCount;
    private int awaitingActivationCount;
    private int awaitingTestConfirmationCount;
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;
    private IEnumerable<CampaignRequest> Campaigns { get; set; } = [];
    private IEnumerable<CampaignRequest> ListCampaigns { get; set; } = [];
    private IEnumerable<CampaignRequest> ActiveCampaigns { get; set; } = [];
    private IEnumerable<CampaignRequest> InActiveCampaigns { get; set; } = [];
    private IEnumerable<CampaignRequest> PendingCampaigns { get; set; } = [];
    private IEnumerable<CampaignRequest> MyCampaigns { get; set; } = [];
    private IEnumerable<CampaignRequest> AwaitingActivation { get; set; } = [];
    private IEnumerable<CampaignRequest> AwaitingTestConfirmation { get; set; } = [];
    private IEnumerable<Comment> Comments { get; set; } = [];
    private int CampaignRequestId;
    private string Vdn = string.Empty;
    private string SearchTrackingCode { get; set; } = string.Empty;
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var myId = user.Claims.Where(x => x.Type == System.Security.Claims.ClaimTypes.NameIdentifier).Select(x => x.Value).FirstOrDefault();
        var response = await CampaignService.GetCampaignRequestsAsync();
        ListCampaigns = response.CampaignRequests!;
        using (var context = await DbContextFactory.CreateDbContextAsync())
        {
            unreadCommentsCount = await context.Comments
                .Include(c => c.Commenter)
                .Where(c => c.CampaignRequest.RequesterId == myId && !c.IsViewed)
                .AsNoTracking()
                .CountAsync();
        }
        if (ListCampaigns is not null)
        {
            Campaigns = ListCampaigns.Where(c => c.RequesterId == myId);
            ActiveCampaigns = Campaigns.Where(c => c.IsActive == true).ToList();
            InActiveCampaigns = Campaigns.Where(c => c.IsActive == false).ToList();
            AwaitingActivation = Campaigns.Where(c => c.IsActive == false && c.IsConfirmedByRequester == true).ToList();
            AwaitingTestConfirmation = Campaigns.Where(c => c.IsActive == false && c.IsPending == true && c.IsConfirmedByRequester == false).ToList();
            
            
            totalCampaignsCount = Campaigns.Count();
            activeCampaignsCount = ActiveCampaigns.Count();
            awaitingTestConfirmationCount = AwaitingTestConfirmation.Count();
            awaitingActivationCount = AwaitingActivation.Count();
        }

    }

    private Func<CampaignRequest, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(SearchTrackingCode))
        {
            return true;
        }
        bool isMatch = !string.IsNullOrEmpty(x.TrackingCode) && x.TrackingCode.Contains(SearchTrackingCode, StringComparison.OrdinalIgnoreCase);

        bool isRelated = x.CampaignRequestMainId is not null && Campaigns.Any(main => main.Id == x.CampaignRequestMainId &&
        !string.IsNullOrEmpty(main.TrackingCode) && main.TrackingCode.Contains(SearchTrackingCode, StringComparison.OrdinalIgnoreCase));

        return isMatch || isRelated;
    };

    private void OnRequestSuccess()
    {
        activeIndex = 0;
        StateHasChanged();
    }
    private void ViewComments(int campaignId)
    {
        NavigationManager.NavigateTo($"/requester-comments/{campaignId}");
    }
    private async Task ConfirmTestingOfVdn(int campaignRequestId)
    {
        var options = new DialogOptions()
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseButton = true,
            };
        CampaignRequestId = campaignRequestId;
        var parameters = new DialogParameters
        {
            { "CampaignRequestId", campaignRequestId },

        };
        DialogService.Show<ConfirmTestOfVDN>("Confirm Test of VDN", parameters, options);

    }
    private async Task TestVDN(string vdn)
    {
        var options = new DialogOptions()
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseButton = true,
            };
        Vdn = vdn;
        var parameters = new DialogParameters
        {
            { "Vdn", vdn },

        };
        DialogService.Show<Components.TestVDN>("Test VDN", parameters, options);
    }
}
