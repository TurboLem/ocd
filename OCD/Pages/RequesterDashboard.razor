@page "/requester-dashboard"
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using OCD.Components
@using OCD.Data
@using OCD.Models
@using OCD.Services.CampaignRequestService
@inject IDbContextFactory<DataContext> DbContextFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ICampaignRequestService CampaignService
@inject IDialogService DialogService
<AuthorizeView Roles="Requester">
    <Authorized>

        <div class="chip-container mb-3 mt-3">
            <MudChipSet T="Color">
                <MudChip Color="Color.Primary" Variant="Variant.Filled">@totalCampaignsCount Total</MudChip>
                <MudChip Color="Color.Success" Variant="Variant.Filled">@activeCampaignsCount Active</MudChip>
                <MudChip Color="Color.Secondary" Variant="Variant.Filled">@awaitingTestConfirmationCount Awaiting VDN test/confirmation</MudChip>
                <MudChip Color="Color.Warning" Variant="Variant.Filled">@awaitingActivationCount Awaiting activation</MudChip>
                <MudChip Color="Color.Error" Variant="Variant.Filled">@unreadCommentsCount Unread Comments</MudChip>
            </MudChipSet>
        </div>
        <MudTabs ApplyEffectsToContainer="true" @bind-ActivePanelIndex="activeIndex" Centered="true">
            <MudTabPanel Text="All Campaigns" Icon="@Icons.Material.Filled.ViewList" ToolTip="Your active and inactive campaigns">


                <div class="mb-3 d-flex align-items-center">
                </div>
                <MudDataGrid T="CampaignRequest"
                             Class="shadow-md rounded-lg  border grid mt-7"
                             Items="@Campaigns"
                             Hover="true"
                             Striped="true"
                             RowsPerPageOptions="new int[] { 10, 25, 50, 100 }"
                             FixedHeader="true"
                             Height="65vh"
                             RowsPerPage="10"
                             Style="background-color:white;"
                             QuickFilter="@_quickFilter">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">All Campaigns</MudText>
                        <MudSpacer />

                        <div class="col-md-4">
                            <MudTextField @bind-Value="SearchTrackingCode"
                                          Placeholder="Search by VDN/Tracking Code"
                                          Adornment="Adornment.Start"
                                          Immediate="true"
                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                          IconSize="Size.Medium" Class="mt-2" />
                        </div>

                    </ToolBarContent>
                    <Columns>
                        <PropertyColumn Property="x => x.Id" Title="Campaign Id" HeaderStyle="white-space:nowrap" />
                        <TemplateColumn Title="Owner" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap">
                            <CellTemplate Context="_context">
                                <MudStack Row>
                                    <MudText Style="font-size:14px">@_context.Item.Requester.Name @_context.Item.Requester.Surname</MudText>
                                </MudStack>
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="x=>x.RequestedDate.Date.ToShortDateString()" Title="Date Requested" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x => x.Description" Title="Description" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x=> x.TrackingCode" Title="VDN/TC" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x=> x.Campaign.Name" Title="Campaign Type" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x=>x.BusinessUnit.UnitName" Title="Business Unit" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x => x.CampaignRequestBrands" Title="Brand" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x=> x.CampaignBrokerCodes" Title="Broker Code" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x=> x.ConnexDiallerCampaign.Name" Title="Dialler Campaign" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x=> x.ConnexDiallerSource.Name" Title="Dialler Source" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x=> x.CommunicationType.Name" Title="Telecom Type" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x=> x.SmsNumber" Title="SMS Number" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x=> x.SharecallNumber" Title="SCN Number" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x=> x.Media.Name" Title="Media" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x=> x.Slot.Name" Title="Slot" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x=> x.SourceBreak.Name" Title="Source Break" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        @* <PropertyColumn Property="x=> x.PackType.Type" Title="Pack" HeaderStyle="white-space:nowrap" /> *@
                        <PropertyColumn Property="x=> x.Publication.Name" Title="Publication" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x=> x.PublicationOwner.Name" Title="Publication Owner" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x=> x.Channel.Name" Title="Channel" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />

                        <PropertyColumn Property="x => x.StartDate!.Value.Date.ToShortDateString()" Title="Start Date" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <PropertyColumn Property="x => x.EndDate!.Value.Date.ToShortDateString()" Title="End Date" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap" />
                        <TemplateColumn CellClass=" justify-end" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap">
                            <CellTemplate Context="_context">
                                <MudStack Row>
                                    <MudButton StartIcon="@Icons.Material.Filled.PlayCircle"
                                               Variant="@Variant.Filled"
                                               Color="Color.Info"
                                               Size="@Size.Small"
                                               OnClick="() => TestVDN(_context.Item.TrackingCode ?? string.Empty)"
                                               Disabled="string.IsNullOrEmpty(_context.Item.TrackingCode)">
                                        Test VDN
                                    </MudButton>
                                </MudStack>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn CellClass=" justify-end" HeaderStyle="white-space:nowrap" CellStyle=" white-space: nowrap">
                            <CellTemplate Context="_context">
                                <MudStack Row>
                                    <MudButton StartIcon="@Icons.Material.Filled.Gavel"
                                               Disabled="_context.Item.IsConfirmedByRequester || string.IsNullOrEmpty(_context.Item.TrackingCode)"
                                               Variant="@Variant.Filled"
                                               Color="Color.Info"
                                               Size="@Size.Small"
                                               OnClick="() => ConfirmTestingOfVdn(_context.Item.Id)">
                                        Confirm VDN Test
                                    </MudButton>
                                </MudStack>
                            </CellTemplate>
