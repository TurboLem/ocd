    private Task<IEnumerable<T>> Search<T>(IEnumerable<T> items, string searchString, Func<T, string> selector)
    {
        if (string.IsNullOrWhiteSpace(searchString))
        {
            return Task.FromResult(items);
        }
        var filteredItems = items
            .Where(item => selector(item).Contains(searchString, StringComparison.OrdinalIgnoreCase))
            .OrderBy(selector)
            .ToList();
        return Task.FromResult<IEnumerable<T>>(filteredItems);
    }
