@page "/add-campaign/three-pack-request"
@using Microsoft.EntityFrameworkCore
@using OCD.DTOs
@using OCD.Data
@using OCD.Models
@using System.Security.Claims
@inject IDbContextFactory<DataContext> DbContextFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
<AuthorizeView Roles="Requester">
    <Authorized>


        <MudCardContent Class="container mt-5">

            <MudExpansionPanels MultiExpansion="true" Outlined="true" Elevation="5">
                <MudForm @ref="form1">
                    <MudExpansionPanel Text="Broker and Dialler Details (CR)">
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <MudAutocomplete T="BrokerCode"
                                                 Label="Broker Code"
                                                 @bind-Value="SelectedBrokerCode"
                                                 SearchFunc="@(async (searchString, token) => await SearchBrokerCodes(searchString, token))"
                                                 ToStringFunc="@(b => b == null ? string.Empty : b.Code)"
                                                 MaxItems="1000"
                                                 AnchorOrigin="Origin.BottomCenter"
                                                 Variant="Variant.Outlined"
                                                 Required="true" />
                            </div>
                            <div class="form-group col-md-4">
                                <MudSelect AnchorOrigin="Origin.BottomCenter" T="int" Label="Connex Dialler Campaign" @bind-Value="campaignRequestCR.ConnexDiallerCampaignId"
                                           Required="true" RequiredError="Please select a dialler campaign" Variant="Variant.Outlined"
                                           SelectedValuesChanged="@(EventCallback.Factory.Create<IEnumerable<int>>(this, OnConnexDiallerCampaignChangedCR))">
                                    @foreach (var campaign in connexDiallerCampaigns)
                                    {
                                        <MudSelectItem T="int" Value="campaign.Id">@campaign.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                            <div class="form-group col-md-4">
                                <MudSelect AnchorOrigin="Origin.BottomCenter" T="int" Label="Connex Dialler Source" @bind-Value="campaignRequestCR.ConnexDiallerSourceId" Required="true" RequiredError="Please select a dialler source" Variant="Variant.Outlined">
                                    @foreach (var source in connexDiallerSourcesCR)
                                    {
                                        <MudSelectItem T="int" Value="source.Id">@source.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                        </div>
                    </MudExpansionPanel>
                </MudForm>
                <MudForm @ref="form2">
                    <MudExpansionPanel Text="Broker and Dialler Details(PNV)">
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <MudAutocomplete T="BrokerCode"
                                                 Label="Broker Code"
                                                 @bind-Value="SelectedBrokerCodePNV"
                                                 SearchFunc="@(async (searchString, token) => await SearchBrokerCodes(searchString, token))"
                                                 ToStringFunc="@(b => b == null ? string.Empty : b.Code)"
                                                 MaxItems="1000"
                                                 AnchorOrigin="Origin.BottomCenter"
                                                 Variant="Variant.Outlined"
                                                 Required="true" />
                            </div>
                            <div class="form-group col-md-4">
                                <MudSelect AnchorOrigin="Origin.BottomCenter" T="int" Label="Connex Dialler Campaign" @bind-Value="campaignRequestPNV.ConnexDiallerCampaignId"
                                           Required="true" RequiredError="Please select a dialler campaign" Variant="Variant.Outlined"
                                           SelectedValuesChanged="@(EventCallback.Factory.Create<IEnumerable<int>>(this, OnConnexDiallerCampaignChangedPNV))">
                                    @foreach (var campaign in connexDiallerCampaigns)
                                    {
                                        <MudSelectItem T="int" Value="campaign.Id">@campaign.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                            <div class="form-group col-md-4">
                                <MudSelect AnchorOrigin="Origin.BottomCenter" T="int" Label="Connex Dialler Source" @bind-Value="campaignRequestPNV.ConnexDiallerSourceId" Required="true" RequiredError="Please select a dialler source" Variant="Variant.Outlined">
                                    @foreach (var source in connexDiallerSourcesPNV)
                                    {
                                        <MudSelectItem T="int" Value="source.Id">@source.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                        </div>
                    </MudExpansionPanel>
                </MudForm>
                <MudForm @ref="form3">
                    <MudExpansionPanel Text="Broker and Dialler Details (PV)">
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <MudAutocomplete T="BrokerCode"
                                                 Label="Broker Code"
                                                 @bind-Value="SelectedBrokerCodePV"
                                                 SearchFunc="@(async (searchString, token) => await SearchBrokerCodes(searchString, token))"
                                                 ToStringFunc="@(b => b == null ? string.Empty : b.Code)"
                                                 MaxItems="1000"
                                                 AnchorOrigin="Origin.BottomCenter"
                                                 Variant="Variant.Outlined"
                                                 Required="true" />
                            </div>
                            <div class="form-group col-md-4">
                                <MudSelect AnchorOrigin="Origin.BottomCenter" T="int" Label="Connex Dialler Campaign" @bind-Value="campaignRequestPV.ConnexDiallerCampaignId"
                                           Required="true" RequiredError="Please select a dialler campaign" Variant="Variant.Outlined"
                                           SelectedValuesChanged="@(EventCallback.Factory.Create<IEnumerable<int>>(this, OnConnexDiallerCampaignChangedPV))">
                                    @foreach (var campaign in connexDiallerCampaigns)
                                    {
                                        <MudSelectItem T="int" Value="campaign.Id">@campaign.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                            <div class="form-group col-md-4">
                                <MudSelect AnchorOrigin="Origin.BottomCenter" T="int" Label="Connex Dialler Source" @bind-Value="campaignRequestPV.ConnexDiallerSourceId" Required="true" RequiredError="Please select a dialler source" Variant="Variant.Outlined">
                                    @foreach (var source in connexDiallerSourcesPV)
                                    {
                                        <MudSelectItem T="int" Value="source.Id">@source.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                        </div>
                    </MudExpansionPanel>
                </MudForm>
                <MudForm @ref="form1">
                    <MudExpansionPanel Text="Campaign Information">
                        <div class="mb-3">
                            <MudTextField Label="SysAid Log" @bind-Value="campaignRequestCR.SysAidLog" Required="true" RequiredError="Please enter a SysAid Log" Variant="Variant.Outlined" />
                            <MudText>
                                No SysAid?
                                <MudLink Href="https://sysaidsvr1.isservices.co.za/servicePortal" Target="_blank" Class="text-blue-500 underline">
                                    Click here
                                </MudLink>
                            </MudText>
                        </div>
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <MudAutocomplete T="CommunicationType"
                                                 Label="Communication Type"
                                                 @bind-Value="SelectedCommunicationType"
                                                 SearchFunc="@(async (searchString, token) => await SearchCommunicationTypes(searchString, token))"
                                                 ToStringFunc="@(c => c == null ? string.Empty : c.Name)"
                                                 MaxItems="1000"
                                                 AnchorOrigin="Origin.BottomCenter"
                                                 Variant="Variant.Outlined"
                                                 Required="true" />
                            </div>
                            <div class="form-group col-md-4">
                                <MudAutocomplete T="BusinessUnit"
                                                 Label="Business Unit"
                                                 @bind-Value="SelectedBusinessUnit"
                                                 SearchFunc="@(async (searchString, token) => await SearchBusinessUnits(searchString, token))"
                                                 ToStringFunc="@(b => b == null ? string.Empty : b.UnitName)"
                                                 MaxItems="1000"
                                                 AnchorOrigin="Origin.BottomCenter"
                                                 Variant="Variant.Outlined"
                                                 Required="true" />
                            </div>
                            <div class="form-group col-md-4">
                                <MudAutocomplete T="Brand"
                                                 Label="Brand"
                                                 @bind-Value="SelectedBrand"
                                                 SearchFunc="@(async (searchString, token) => await SearchBrands(searchString, token))"
                                                 ToStringFunc="@(b => b == null ? string.Empty : b.Name)"
                                                 MaxItems="1000"
                                                 AnchorOrigin="Origin.BottomCenter"
                                                 Variant="Variant.Outlined"
                                                 Required="true" />
                            </div>

                        </div>
                        <MudTextField @bind-Value="campaignRequestCR.Description" Label="Campaign Name" Required="true" RequiredError="Please fill in the name of your campaign" Variant="Variant.Outlined" />
                    </MudExpansionPanel>

                    <!-- Contact Information Section -->
                    <MudExpansionPanel Text="Contact Information">
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <MudTextField @bind-Value="campaignRequestCR.SmsNumber" Label="ShortCode Number" Disabled="true" Variant="Variant.Outlined" />
                            </div>
                            <div class="form-group col-md-4">
                                <MudTextField @bind-Value="campaignRequestCR.SharecallNumber" Label="ShareCall Number" Disabled="true" Variant="Variant.Outlined" />
                            </div>
                            <div class="form-group col-md-4">
                                <MudTextField @bind-Value="campaignRequestCR.TrackingCode" Label="VDN/Tracking Code" Disabled="true" Variant="Variant.Outlined" />
                            </div>
                        </div>
                    </MudExpansionPanel>

                    <!-- Broker and Campaign Details Section -->
                    <!-- Channel and Source Details Section -->
                    <MudExpansionPanel Text="Channel and Source Details">
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <MudAutocomplete T="Channel"
                                                 Label="Channel"
                                                 @bind-Value="SelectedChannel"
                                                 SearchFunc="@(async (searchString, token) => await SearchChannels(searchString, token))"
                                                 ToStringFunc="@(c => c == null ? string.Empty : c.Name)"
                                                 MaxItems="1000"
                                                 AnchorOrigin="Origin.BottomCenter"
                                                 Variant="Variant.Outlined"
                                                 Required="true" />
                            </div>
                            <div class="form-group col-md-4">
                                <MudAutocomplete T="Source"
                                                 Label="Source"
                                                 @bind-Value="SelectedSource"
                                                 SearchFunc="@(async (searchString, token) => await SearchSources(searchString, token))"
                                                 ToStringFunc="@(s => s == null ? string.Empty : s.Name)"
                                                 MaxItems="1000"
                                                 AnchorOrigin="Origin.BottomCenter"
                                                 Variant="Variant.Outlined"
                                                 Required="true" />
                            </div>
                            <div class="form-group col-md-4">
                                <MudAutocomplete T="SourceBreak"
                                                 Label="Source Break"
                                                 @bind-Value="SelectedSourceBreak"
                                                 SearchFunc="@(async (searchString, token) => await SearchSourceBreaks(searchString, token))"
                                                 ToStringFunc="@(s => s == null ? string.Empty : s.Name)"
                                                 MaxItems="1000"
                                                 AnchorOrigin="Origin.BottomCenter"
                                                 Variant="Variant.Outlined"
                                                 Required="true" />
                            </div>
                        </div>
                    </MudExpansionPanel>

                    <!-- Media and Publication Details Section -->
                    <MudExpansionPanel Text="Media and Publication Details">
                        <div class="form-row">
                            <div class="form-group col-md-6">
                                <MudAutocomplete T="Campaign"
                                                 Label="Campaign"
                                                 @bind-Value="SelectedCampaign"
                                                 SearchFunc="@(async (searchString, token) => await SearchCampaigns(searchString, token))"
                                                 ToStringFunc="@(c => c == null ? string.Empty : c.Name)"
                                                 MaxItems="1000"
                                                 AnchorOrigin="Origin.BottomCenter"
                                                 Variant="Variant.Outlined"
                                                 Required="true" />
                            </div>
                            <div class="form-group col-md-6">
                                <MudAutocomplete T="Media"
                                                 Label="Media Type"
                                                 @bind-Value="SelectedMedia"
                                                 SearchFunc="@(async (searchString, token) => await SearchMediaTypes(searchString, token))"
                                                 ToStringFunc="@(m => m == null ? string.Empty : m.Name)"
                                                 MaxItems="1000"
                                                 AnchorOrigin="Origin.BottomCenter"
                                                 Variant="Variant.Outlined"
                                                 Required="true" />
                            </div>
                            <div class="form-group col-md-6">
                                <MudAutocomplete T="PublicationOwner"
                                                 Label="Publication Owner"
                                                 @bind-Value="SelectedPublicationOwner"
                                                 SearchFunc="@(async (searchString, token) => await SearchPublicationOwners(searchString, token))"
                                                 ToStringFunc="@(p => p == null ? string.Empty : p.Name)"
                                                 MaxItems="1000"
                                                 AnchorOrigin="Origin.BottomCenter"
                                                 Variant="Variant.Outlined"
                                                 Required="true" />
                            </div>
                            <div class="form-group col-md-6">
                                <MudAutocomplete T="Publication"
                                                 Label="Publication"
                                                 @bind-Value="SelectedPublication"
                                                 SearchFunc="@(async (searchString, token) => await SearchPublications(searchString, token))"
                                                 ToStringFunc="@(p => p == null ? string.Empty : p.Name)"
                                                 MaxItems="1000"
                                                 AnchorOrigin="Origin.BottomCenter"
                                                 Variant="Variant.Outlined"
                                                 Required="true" />
                            </div>
                            <div class="form-group col-md-6">
                                <MudAutocomplete T="Slot"
                                                 Label="Slot"
                                                 @bind-Value="SelectedSlot"
                                                 SearchFunc="@(async (searchString, token) => await SearchSlots(searchString, token))"
                                                 ToStringFunc="@(s => s == null ? string.Empty : s.Name)"
                                                 MaxItems="1000"
                                                 AnchorOrigin="Origin.BottomCenter"
                                                 Variant="Variant.Outlined"
                                                 Required="true" />
                            </div>
                            <div class="form-group col-md-6">
                                <MudItem>
                                    <MudDateRangePicker PickerVariant="PickerVariant.Dialog" Variant="Variant.Outlined" Label="Select Date Range" @bind-DateRange="DateRangeCR" InputClass="w-full rounded-md border-gray-200 bg-gray-50 border-2" Required="true" />
                                </MudItem>
                            </div>
                        </div>
                    </MudExpansionPanel>
                </MudForm>
            </MudExpansionPanels>
            <br />
            <MudCardActions>
                <MudButton Color="Color.Warning" Variant="Variant.Filled" OnClick="OnConfirm3Pack">Request Campaign</MudButton>
            </MudCardActions>
        </MudCardContent>
    </Authorized>
    <NotAuthorized>
        <MudAlert Severity="Severity.Error">You are not authorized to view this page.</MudAlert>
    </NotAuthorized>
</AuthorizeView>
@code {
    private MudForm form1;
    private MudForm form2;
    private MudForm form3;
    private CampaignRequestDTO campaignRequestCR = new();
    private CampaignRequestDTO campaignRequestPNV = new();
    private CampaignRequestDTO campaignRequestPV = new();
    private bool ShowChildForms = false;
    private bool ShowChildForm2 = false;
    private bool ShowConfirmButton = false;
    private string selectedBrand;
    private string selectedBrokerCode;
    private List<Campaign> campaigns = new();
    private List<PackType> packTypes = new();
    private List<Channel> channels = new();
    private List<Brand> brands = new();
    private List<Media> mediaTypes = new();
    private List<Slot> slots = new();
    private List<Source> sources = new();
    private List<BusinessUnit> businessUnits = new();
    private List<SourceBreak> sourceBreaks = new();
    private List<Publication> publications = new();
    private List<PublicationOwner> publicationOwners = new();
    private ApplicationUser Requester { get; set; }
    private List<CommunicationType> communicationTypes = new();
    private List<ConnexDiallerCampaign> connexDiallerCampaigns = new();
    private List<ConnexDiallerSource> connexDiallerSources = new();
    private List<BrokerCode> brokerCodes = new();
    private DateRange _dateRangeCR;
    private DateRange DateRangeCR
    {
        get => _dateRangeCR;
        set
        {
            if (_dateRangeCR != value)
            {
                _dateRangeCR = value;
                campaignRequestCR.StartDate = value.Start;
                campaignRequestCR.EndDate = value.End;
            }
        }
    }
    private DateRange _dateRangePV;
    private DateRange DateRangePV
    {
        get => _dateRangePV;
        set
        {
            if (_dateRangePV != value)
            {
                _dateRangePV = value;
                campaignRequestPNV.StartDate = value.Start;
                campaignRequestPNV.EndDate = value.End;
            }
        }
    }
    private DateRange _dateRangePNV;
    private DateRange DateRangePNV
    {
        get => _dateRangePNV;
        set
        {
            if (_dateRangePNV != value)
            {
                _dateRangePNV = value;
                campaignRequestPV.StartDate = value.Start;
                campaignRequestPV.EndDate = value.End;
            }
        }
    }
    private List<ConnexDiallerSource> connexDiallerSourcesCR = new List<ConnexDiallerSource>();
    private List<ConnexDiallerSource> connexDiallerSourcesPNV = new List<ConnexDiallerSource>();
    private List<ConnexDiallerSource> connexDiallerSourcesPV = new List<ConnexDiallerSource>();
    private string userId = string.Empty;
    private Publication SelectedPublication { get; set; } = new();
    private PublicationOwner SelectedPublicationOwner { get; set; } = new();
    private Slot SelectedSlot { get; set; } = new();
    private Media SelectedMedia { get; set; } = new();
    private Channel SelectedChannel { get; set; } = new();
    private Source SelectedSource { get; set; } = new();
    private SourceBreak SelectedSourceBreak { get; set; } = new();
    private BusinessUnit SelectedBusinessUnit { get; set; } = new();
    private CommunicationType SelectedCommunicationType { get; set; } = new();
    private ConnexDiallerCampaign SelectedConnexDiallerCampaign { get; set; } = new();
    private ConnexDiallerSource SelectedConnexDiallerSource { get; set; } = new();
    private BrokerCode SelectedBrokerCode { get; set; } = new();
    private ConnexDiallerCampaign SelectedConnexDiallerCampaignPV { get; set; } = new();
    private ConnexDiallerSource SelectedConnexDiallerSourcePV { get; set; } = new();
    private BrokerCode SelectedBrokerCodePV { get; set; } = new();
    private ConnexDiallerCampaign SelectedConnexDiallerCampaignPNV { get; set; } = new();
    private ConnexDiallerSource SelectedConnexDiallerSourcePNV { get; set; } = new();
    private BrokerCode SelectedBrokerCodePNV { get; set; } = new();
    private Campaign SelectedCampaign { get; set; } = new();
    private PackType SelectedPackType { get; set; } = new();
    private Brand SelectedBrand { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        using (var context = await DbContextFactory.CreateDbContextAsync())
        {
            campaigns = await context.Campaigns.AsNoTracking().ToListAsync();
            packTypes = await context.PackTypes.AsNoTracking().ToListAsync();
            channels = await context.Channels.AsNoTracking().ToListAsync();
            brands = await context.Brands.AsNoTracking().ToListAsync();
            mediaTypes = await context.Media.AsNoTracking().ToListAsync();
            slots = await context.Slots.AsNoTracking().ToListAsync();
            sources = await context.Sources.AsNoTracking().ToListAsync();
            businessUnits = await context.BusinessUnits.AsNoTracking().ToListAsync();
            sourceBreaks = await context.SourceBreaks.AsNoTracking().ToListAsync();
            publications = await context.Publications.AsNoTracking().ToListAsync();
            publicationOwners = await context.PublicationOwners.AsNoTracking().ToListAsync();
            communicationTypes = await context.CommunicationTypes.AsNoTracking().ToListAsync();
            connexDiallerCampaigns = await context.ConnexDiallerCampaigns.AsNoTracking().ToListAsync();
            brokerCodes = await context.BrokerCodes.AsNoTracking().ToListAsync();
            Requester = await context.Users.FirstOrDefaultAsync(x => x.Email == user.Identity!.Name) ?? new();

        }
        DateRangeCR = new DateRange(campaignRequestCR.StartDate, campaignRequestCR.EndDate);
        DateRangePV = new DateRange(campaignRequestPNV.StartDate, campaignRequestPNV.EndDate);
        DateRangePNV = new DateRange(campaignRequestPV.StartDate, campaignRequestPV.EndDate);
    }
    private async Task OnConnexDiallerCampaignChanged(IEnumerable<int> selectedValues)
    {
        var selectedDiallerCampaignId = selectedValues.FirstOrDefault();
        using var context = await DbContextFactory.CreateDbContextAsync();
        connexDiallerSources = await context.ConnexDiallerSources
            .Where(x => x.ConnexDiallerCampaignId == selectedDiallerCampaignId)
            .AsNoTracking()
            .ToListAsync();

        StateHasChanged();
    }
    private async Task OnConnexDiallerCampaignChangedCR(IEnumerable<int> selectedValues)
    {
        var selectedCampaignId = selectedValues.FirstOrDefault();
        connexDiallerSourcesCR = await GetDiallerSourcesByCampaignId(selectedCampaignId);
    }

    private async Task OnConnexDiallerCampaignChangedPNV(IEnumerable<int> selectedValues)
    {
        var selectedCampaignId = selectedValues.FirstOrDefault();
        connexDiallerSourcesPNV = await GetDiallerSourcesByCampaignId(selectedCampaignId);
    }

    private async Task OnConnexDiallerCampaignChangedPV(IEnumerable<int> selectedValues)
    {
        var selectedCampaignId = selectedValues.FirstOrDefault();
        connexDiallerSourcesPV = await GetDiallerSourcesByCampaignId(selectedCampaignId);
    }

    private async Task<List<ConnexDiallerSource>> GetDiallerSourcesByCampaignId(int campaignId)
    {
        using var context = await DbContextFactory.CreateDbContextAsync();
        return await context.ConnexDiallerSources
            .Where(source => source.ConnexDiallerCampaignId == campaignId)
            .ToListAsync();
    }
    private void OnDateRangeChanged(DateRange newDateRange)
    {
        campaignRequestCR.StartDate = newDateRange.Start;
        campaignRequestCR.EndDate = newDateRange.End;
        campaignRequestPNV.StartDate = newDateRange.Start;
        campaignRequestPNV.EndDate = newDateRange.End;
        campaignRequestPV.StartDate = newDateRange.Start;
        campaignRequestPV.EndDate = newDateRange.End;
    }
    private async Task OnValidSubmit()
    {
        // Logic to handle form submission
    }

    private async Task OnConfirm3Pack()
    {
        if (form1.IsValid && form2.IsValid && form3.IsValid)
        {
            using (var context = DbContextFactory.CreateDbContext())
            {
                var mainCampaignRequest = new CampaignRequest
                    {
                        SysAidLog = campaignRequestCR.SysAidLog,
                        Description = $"{campaignRequestCR.Description} CR",
                        CampaignId = SelectedCampaign.Id,
                        CommunicationTypeId = SelectedCommunicationType.Id,
                        BusinessUnitId = SelectedBusinessUnit.Id,
                        CampaignRequestBrands = SelectedBrand.Name,
                        SmsNumber = null,
                        SharecallNumber = null,
                        ChannelId = SelectedChannel.Id,
                        SourceId = SelectedSource.Id,
                        SourceBreakId = SelectedSourceBreak.Id,
                        ConnexDiallerCampaignId = campaignRequestCR.ConnexDiallerCampaignId,
                        ConnexDiallerSourceId = campaignRequestCR.ConnexDiallerSourceId,
                        SlotId = SelectedSlot.Id,
                        MediaId = SelectedMedia.Id,
                        PublicationOwnerId = SelectedPublicationOwner.Id,
                        PublicationId = SelectedPublication.Id,
                        CampaignBrokerCodes = SelectedBrokerCode.Code,
                        StartDate = campaignRequestCR.StartDate,
                        EndDate = campaignRequestCR.EndDate,
                        IsActive = false,
                        IsPending = false,
                        TrackingCode = null,
                        CampaignRequestMainId = null,
                        PackTypeId = 2,
                        RequesterId = userId,
                        ActionedBy = null,
                        ActionedDate = null,
                        IsConfirmedByRequester = false,
                        RequestedDate = DateTime.Now

                    };
                context.CampaignRequests.Add(mainCampaignRequest);
                await context.SaveChangesAsync();

                var mainCampaignRequestId = mainCampaignRequest.Id;

                var subCampaignRequests = new List<CampaignRequest>
            {
                new CampaignRequest
                {
                    SysAidLog = campaignRequestCR.SysAidLog,
                    CampaignId = SelectedCampaign.Id,
                    Description = $"{campaignRequestCR.Description} PNV",
                    CampaignRequestMainId = mainCampaignRequestId,
                    CommunicationTypeId = SelectedCommunicationType.Id,
                    BusinessUnitId = SelectedBusinessUnit.Id,
                    CampaignRequestBrands = SelectedBrand.Name,
                    SmsNumber = null,
                    SharecallNumber = null,
                    ChannelId = SelectedChannel.Id,
                    SourceId = SelectedSource.Id,
                    SourceBreakId = SelectedSourceBreak.Id,
                    ConnexDiallerCampaignId = campaignRequestPNV.ConnexDiallerCampaignId,
                    ConnexDiallerSourceId = campaignRequestPNV.ConnexDiallerSourceId,
                    SlotId = SelectedSlot.Id,
                    MediaId = SelectedMedia.Id,
                    PublicationOwnerId = SelectedPublicationOwner.Id,
                    PublicationId = SelectedPublication.Id,
                    CampaignBrokerCodes = SelectedBrokerCodePNV.Code,
                    StartDate = campaignRequestCR.StartDate,
                    EndDate = campaignRequestCR.EndDate,
                    IsActive = false,
                    IsPending = false,
                    TrackingCode = null,
                    PackTypeId = 2,
                    RequesterId = userId,
                    ActionedBy = null,
                    ActionedDate = null,
                    IsConfirmedByRequester = false,
                    RequestedDate = DateTime.Now
                },
                new CampaignRequest
                {
                    SysAidLog = campaignRequestCR.SysAidLog,
                     CampaignId = SelectedCampaign.Id,
                    Description = $"{campaignRequestCR.Description} PV",
                    CampaignRequestMainId = mainCampaignRequestId,
                    CommunicationTypeId = SelectedCommunicationType.Id,
                    BusinessUnitId = SelectedBusinessUnit.Id,
                    CampaignRequestBrands = SelectedBrand.Name,
                    SmsNumber = null,
                    SharecallNumber = null,
                    ChannelId = SelectedChannel.Id,
                    SourceId = SelectedSource.Id,
                    SourceBreakId = SelectedSourceBreak.Id,
                    ConnexDiallerCampaignId = campaignRequestPV.ConnexDiallerCampaignId,
                    ConnexDiallerSourceId = campaignRequestPV.ConnexDiallerSourceId,
                    SlotId = SelectedSlot.Id,
                    MediaId = SelectedMedia.Id,
                    PublicationOwnerId = SelectedPublicationOwner.Id,
                    PublicationId = SelectedPublication.Id,
                    CampaignBrokerCodes = SelectedBrokerCodePV.Code,
                    StartDate = campaignRequestCR.StartDate,
                    EndDate = campaignRequestCR.EndDate,
                    IsActive = false,
                    IsPending = false,
                    TrackingCode = null,
                    PackTypeId = 2,
                    RequesterId = Requester.Id,
                    ActionedBy = null,
                    ActionedDate = null,
                    RequestedDate = DateTime.Now,
                    IsConfirmedByRequester = false
                }
            };
                context.CampaignRequests.AddRange(subCampaignRequests);
                var result = await context.SaveChangesAsync();
                if (result > 0)
                {
                    Snackbar.Add("Campaign Request created successfully!", Severity.Success);
                    NavigationManager.NavigateTo("/requester-dashboard");

                    campaignRequestCR = new();
                    campaignRequestPNV = new();
                    campaignRequestPV = new();
                }
                else
                {
                    Snackbar.Add("An error occurred while creating the Campaign Request. Please try again.", Severity.Error);
                }
            }
        }
        else
        {
            Snackbar.Add("Please fill in all required fields", Severity.Error);
        }
    }
