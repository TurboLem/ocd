                                        }
                                    </MudSelect>
                                </div>
                                <div class="form-group col-md-4">
                                    <MudSelect AnchorOrigin="Origin.BottomCenter" T="int" Label="Publication" @bind-Value="parentCampaignRequest.PublicationId" Required="true" RequiredError="Please select a dialler source" Variant="Variant.Outlined">
