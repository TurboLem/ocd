@page "/add-campaign/multi-brand-request"
@using Microsoft.EntityFrameworkCore
@using OCD.DTOs
@using OCD.Data
@using OCD.Models
@using System.Security.Claims
@inject IDialogService DialogService
@inject IDbContextFactory<DataContext> DbContextFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISnackbar Snackbar

<AuthorizeView Roles="Requester">
    <Authorized>
        
            <MudCardContent Class="container mt-5">
                <MudExpansionPanels MultiExpansion="true" Outlined="true" Elevation="2">
                    <MudForm @ref="form1">
                        <MudExpansionPanel Text="Main Campaign Details" Expanded="true">
                            <div class="mb-3">
                                <MudTextField Label="SysAid Log" @bind-Value="parentCampaignRequest.SysAidLog" Required="true" RequiredError="Please enter a SysAid Log" Variant="Variant.Outlined" />
                                <MudText>
                                    No SysAid?
                                    <MudLink Href="https://sysaidsvr1.isservices.co.za/servicePortal" Target="_blank" Class="text-blue-500 underline">
                                        Click here
                                    </MudLink>
                                </MudText>
                            </div>


                            <div class="form-row">
                                <div class="form-group col-md-4 align-content-center">
                                    <MudRadioGroup @bind-Value="isSelectOwnBrand">
                                        <MudText>I want to select a set number of brands</MudText>
                                        <MudRadio Value="true">Yes</MudRadio>
                                        <MudRadio Value="false">No</MudRadio>
                                    </MudRadioGroup>
                                </div>
                                @if (isSelectOwnBrand)
