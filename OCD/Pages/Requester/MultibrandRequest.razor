                                                   MultiSelection="true">
                                            @foreach (var brand in brands)
                                            {
                                                <MudSelectItem Value="@brand.Name">@brand.Name</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </div>
                                    <div class="form-group col-md-4">
                                        <MudSelect AnchorOrigin="Origin.BottomCenter" T="string" Label="Broker Code" @bind-Value="parentCampaignRequest.CampaignBrokerCodes" Required="true" RequiredError="Please select a broker code" Variant="Variant.Outlined" MultiSelection="true">
                                            @foreach (var brokerCode in brokerCodes)
                                            {
                                                <MudSelectItem Value="@brokerCode.Code">@brokerCode.Code</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </div>
