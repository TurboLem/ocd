                    <MudExpansionPanel Text="Business Unit, Channel and Source Details">
                        <div class="form-row">
                            <div class="form-group col-md-3">
                                <MudSelect AnchorOrigin="Origin.BottomCenter" T="int" Label="Communication Type" @bind-Value="parentCampaignRequest.CommunicationTypeId" Required="true" RequiredError="Please select a communication type" Variant="Variant.Outlined">
