@code {
    private bool isSelectOwnBrand = true;
    private bool isMultiSelect = true; 
    private MudForm form1 = default!;
    private CampaignRequestDTO parentCampaignRequest = new();
    private List<CampaignRequestDTO> subCampaignRequests { get; set; } = new List<CampaignRequestDTO>();
    private IEnumerable<string> selectedBrands { get; set; } = new HashSet<string>();
    private List<string> brandsSelectList = new List<string>();
    private string placeholder = "";
    private string selectedBrokerCode;
    private List<Campaign> campaigns = new();
    private List<PackType> packTypes = new();
    private List<Channel> channels = new();
    private List<Brand> brands = new();
    private List<Media> mediaTypes = new();
    private List<Slot> slots = new();
    private List<Source> sources = new();
    private List<BusinessUnit> businessUnits = new();
    private List<SourceBreak> sourceBreaks = new();
    private List<Publication> publications = new();
    private List<PublicationOwner> publicationOwners = new();
    private List<CommunicationType> communicationTypes = new();
    private List<ConnexDiallerCampaign> connexDiallerCampaigns = new();
    private List<ConnexDiallerSource> connexDiallerSources = new();
    private List<BrokerCode> brokerCodes = new();
    private string userId = string.Empty;
    private DateRange _dateRangeCR;
    private DateRange DateRangeCR
    {
        get => _dateRangeCR;
        set
        {
            if (_dateRangeCR != value)
            {
                _dateRangeCR = value;
                parentCampaignRequest.StartDate = value.Start;
                parentCampaignRequest.EndDate = value.End;
            }
        }
    }

    private CampaignRequestDTO GetRequestAt(int index)
    {
        if (subCampaignRequests != null && index >= 0 && index < subCampaignRequests.Count)
        {
            return subCampaignRequests[index];
        }
        return null!;
    }


    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        using (var context = DbContextFactory.CreateDbContext())
        {
            campaigns = await context.Campaigns.AsNoTracking().ToListAsync();
            packTypes = await context.PackTypes.AsNoTracking().ToListAsync();
            channels = await context.Channels.AsNoTracking().ToListAsync();
            brands = await context.Brands.AsNoTracking().ToListAsync();
            mediaTypes = await context.Media.AsNoTracking().ToListAsync();
            slots = await context.Slots.AsNoTracking().ToListAsync();
            sources = await context.Sources.AsNoTracking().ToListAsync();
            businessUnits = await context.BusinessUnits.AsNoTracking().ToListAsync();
            sourceBreaks = await context.SourceBreaks.AsNoTracking().ToListAsync();
            publications = await context.Publications.AsNoTracking().ToListAsync();
            publicationOwners = await context.PublicationOwners.AsNoTracking().ToListAsync();
            communicationTypes = await context.CommunicationTypes.AsNoTracking().ToListAsync();
            connexDiallerCampaigns = await context.ConnexDiallerCampaigns.AsNoTracking().ToListAsync();
            brokerCodes = await context.BrokerCodes.AsNoTracking().ToListAsync();
            
        }
        DateRangeCR = new DateRange(parentCampaignRequest.StartDate, parentCampaignRequest.EndDate);
    }

    private async Task OnSubmit()
    {
        if (form1.IsValid)
        {
            using (var context = DbContextFactory.CreateDbContext())
            {
                var mainCampaignRequest = new CampaignRequest
                    {
                        SysAidLog = parentCampaignRequest.SysAidLog,
                        Description = parentCampaignRequest.Description,
                        CampaignId = parentCampaignRequest.CampaignId,
                        CommunicationTypeId = parentCampaignRequest.CommunicationTypeId,
                        BusinessUnitId = parentCampaignRequest.BusinessUnitId,
                        CampaignRequestBrands = (selectedBrands is not null && selectedBrands.Any())
            ? string.Join(",", selectedBrands)
            : placeholder,
                        SmsNumber = null,
                        SharecallNumber = null,
                        ChannelId = parentCampaignRequest.ChannelId,
                        SourceId = parentCampaignRequest.SourceId,
                        SourceBreakId = parentCampaignRequest.SourceBreakId,
                        ConnexDiallerCampaignId = parentCampaignRequest.ConnexDiallerCampaignId,
                        ConnexDiallerSourceId = parentCampaignRequest.ConnexDiallerSourceId,
                        SlotId = parentCampaignRequest.SlotId,
                        MediaId = parentCampaignRequest.MediaId,
                        PublicationOwnerId = parentCampaignRequest.PublicationOwnerId,
                        PublicationId = parentCampaignRequest.PublicationId,
                        CampaignBrokerCodes = parentCampaignRequest.CampaignBrokerCodes,
                        StartDate = parentCampaignRequest.StartDate,
                        EndDate = parentCampaignRequest.EndDate,
                        IsActive = false,
                        IsPending = false,
                        TrackingCode = null,
                        CampaignRequestMainId = null,
                        PackTypeId = null,
                        RequesterId = userId, 
                        ActionedBy = null,
                        ActionedDate = null,
                        IsConfirmedByRequester = false,
                        RequestedDate = DateTime.Now,
                    };
                context.CampaignRequests.Add(mainCampaignRequest);
                await context.SaveChangesAsync();


                foreach (var subCampaignRequest in subCampaignRequests)
                {
                    var subCampaign = new CampaignRequest
                        {
                            SysAidLog = parentCampaignRequest.SysAidLog,
                            Description = subCampaignRequest.Description,
                            SourceId = parentCampaignRequest.SourceId,
                            CampaignId = parentCampaignRequest.CampaignId,
                            CommunicationTypeId = parentCampaignRequest.CommunicationTypeId,
                            BusinessUnitId = parentCampaignRequest.BusinessUnitId,
                            CampaignRequestBrands = subCampaignRequest.CampaignRequestBrands,
                            SmsNumber = null,
                            SharecallNumber = null,
                            ChannelId = parentCampaignRequest.ChannelId,
                            SourceBreakId = parentCampaignRequest.SourceBreakId,
                            ConnexDiallerCampaignId = subCampaignRequest.ConnexDiallerCampaignId,
                            ConnexDiallerSourceId = subCampaignRequest.ConnexDiallerSourceId,
                            SlotId = parentCampaignRequest.SlotId,
                            MediaId = parentCampaignRequest.MediaId,
                            PublicationOwnerId = subCampaignRequest.PublicationOwnerId,
                            PublicationId = subCampaignRequest.PublicationId,
                            TrackingCode = null,
                            CampaignBrokerCodes = subCampaignRequest.CampaignBrokerCodes,
                            StartDate = parentCampaignRequest.StartDate,
                            EndDate = parentCampaignRequest.EndDate,
                            IsActive = false,
                            IsPending = false,
                            CampaignRequestMainId = mainCampaignRequest.Id,
                            PackTypeId = null,
                            RequesterId = userId,
                            ActionedBy = null,
                            ActionedDate = null,
                            IsConfirmedByRequester = false,
                            RequestedDate = mainCampaignRequest.RequestedDate,

                        };
                    context.CampaignRequests.Add(subCampaign);
                }
                await context.SaveChangesAsync();
                Snackbar.Add("Sub Campaign Requests created successfully!", Severity.Success);
                subCampaignRequests.Clear();
                parentCampaignRequest = new();
            }
        }
        else
        {
            Snackbar.Add("Please fill in all required fields.", Severity.Error);
        }
    }
    private async Task OnConnexDiallerCampaignChanged(IEnumerable<int> selectedValues)
    {
        var selectedDiallerCampaignId = selectedValues.FirstOrDefault();
        using var context = DbContextFactory.CreateDbContext();
        connexDiallerSources = await context.ConnexDiallerSources
            .Where(x => x.ConnexDiallerCampaignId == selectedDiallerCampaignId)
            .AsNoTracking()
            .ToListAsync();

        StateHasChanged();
    }

    private async Task OnBrandChanged(IEnumerable<string> selectedBrands)
    {
        var selectedBrandList = selectedBrands.ToList();

        if (selectedBrandList.Contains("TELESURE MULTIBRAND"))
        {           
            InitializeSubCampaignRequests(5);
        }
        else
        {
            InitializeSubCampaignRequests(selectedBrandList.Count);
        }
        StateHasChanged(); 
    }
    private void InitializeSubCampaignRequests(int count)
    {
        subCampaignRequests.Clear();
        for (int i = 0; i < count; i++)
        {
            subCampaignRequests.Add(new CampaignRequestDTO());
        }
       
    }
}
