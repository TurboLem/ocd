                            <div class="form-group col-md-3">
                                <MudSelect AnchorOrigin="Origin.BottomCenter" T="int" Label="Business Unit" @bind-Value="parentCampaignRequest.BusinessUnitId" Required="true" RequiredError="Please select a channel" Variant="Variant.Outlined">
                                    @foreach (var businessUnit in businessUnits)
