


<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">Do you want to select a select number of brands?</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="OnSubmit" >Yes</MudButton>
        <MudButton Color="Color.Secondary" OnClick="() => MudDialog.Close(DialogResult.Ok(false))">No</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter]
    public EventCallback OnRequestSuccess { get; set; }
    private async Task OnSubmit()
    {
        MudDialog.Close(DialogResult.Ok(true));
        if (OnRequestSuccess.HasDelegate)
        {
            await OnRequestSuccess.InvokeAsync();
        }
    }
}
