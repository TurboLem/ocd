@using Microsoft.EntityFrameworkCore
@using OCD.Data
@using OCD.Models
@using OCD.Services
@using OCD.Services.CampaignRequestService
@using System.Security.Claims
@inject IDbContextFactory<DataContext> DbContextFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ICampaignRequestService CampaignRequestService
@inject IEmailService EmailService

<MudDialog>
    <DialogContent>
        <MudForm @bind-IsValid="isValid" @ref="form">
            <MudCheckBox @bind-Value="isTested" Label="I have tested the new campaign & received a call back" Required="true" />
            <MudCheckBox @bind-Value="isVerified" Label="I have verified with agent that brand/tracking code/vdn is correct" Required="true" />
            <MudCheckBox @bind-Value="isConfirmed" Label="I have confirmed with agent to close contact/lead as a test" Required="true" />
            <MudCheckBox @bind-Value="isApproved" Label="I have approved the campaign to go live" Required="true" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Warning" Disabled="!isValid || isLoading" OnClick="Submit">Submit</MudButton>
        @if (isLoading)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Medium" Class="ml-2" />
        }
    </DialogActions>
</MudDialog>

@code {
    private MudForm form;
    private bool isValid;
    private bool isLoading = false;
    private bool isTested = false;
    private bool isVerified = false;
    private bool isConfirmed = false;
    private bool isApproved = false;
    [CascadingParameter]
    private MudDialogInstance MudDialog { get; set; }
    [Parameter]
    public int CampaignRequestId { get; set; }
    private ApplicationUser LoggedInUser { get; set; }
    private CampaignRequest Campaign { get; set; } = new();
    private ApplicationUser OpsMemberHandlingThisCampaign { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {

        Campaign = await CampaignRequestService.GetCampaignRequestByIdAsync(CampaignRequestId);


    }
    private async Task Submit()
    {

        if (isLoading)
        {
            return;
        }
        isLoading = true;
        StateHasChanged();
        try
        {
            await form.Validate();
            if (!form.IsValid)
            {
                Snackbar.Add("Please confirm all the checkboxes", Severity.Error);
                return;
            }
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var name = user.FindFirst(ClaimTypes.GivenName)?.Value;
            var surname = user.FindFirst(ClaimTypes.Surname)?.Value;

            Campaign.IsConfirmedByRequester = true;
            using (var context = await DbContextFactory.CreateDbContextAsync())
            {
                using (var transaction = await context.Database.BeginTransactionAsync())
                {
                    try
                    {

                        context.Update(Campaign);
                        await context.SaveChangesAsync();

                        OpsMemberHandlingThisCampaign = await context.Users.FirstOrDefaultAsync(u => u.Id == Campaign.ActionedBy);

                        string message = $@"
                                <html>
                                <body>
                                    <p>Dear {OpsMemberHandlingThisCampaign!.Name} {OpsMemberHandlingThisCampaign.Surname},</p>
                                    <p><strong>{name} {surname}</strong> has confirmed the following for {Campaign.Description}:</p>
                                    <ul>
                                        <li>I have tested the new campaign & received a call back.</li>
                                        <li>I have verified with the agent that brand/tracking code/VDN is correct.</li>
                                        <li>I have confirmed with the agent to close contact/lead as a test.</li>
                                        <li>I have approved the campaign to go live.</li>
                                    </ul>
                                </body>
                                </html>";

                        // await EmailService.SendEmail(subject: $"Test VDN Confirmation for {Campaign.Description}", message: message, emailAddress: OpsMemberHandlingThisCampaign.Email!);
                        await transaction.CommitAsync();
                        Snackbar.Add("Confirmation email has been sent to Ops team", Severity.Success);

                    }
                    catch (Exception exception)
                    {
                        await transaction.RollbackAsync();
                        Snackbar.Add("An error occurred while confirming. Please try again later", Severity.Error);
                    }
                }
            }
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
        MudDialog.Close();
    }
    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
