@page
@model OCD.Areas.Identity.Pages.Account.ForgotPasswordConfirmationModel
@{
    <div class="d-flex align-items-center justify-content-center min-vh-100">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-8 col-lg-6 col-xl-4">
                    <div class="card shadow-2-strong" style="background-color:#f5f7fa; padding: 2rem 1rem;">
                        <div class="card-body text-center">
                            <h3 class="mb-4">Password Reset</h3>
                            <p>If an account matching the provided email exists, a password reset link has been sent.</p>
                            <a href="/identity/account/login" class="btn btn-sm" style="background:#f48121; color:white">Back to Login</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

